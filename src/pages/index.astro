---
import { getCollection } from "astro:content";
import "../styles/global.css";

const rhythms = (await getCollection("rhythms")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
const isCombo = (rhythm: (typeof rhythms)[number]) =>
  rhythm.slug.startsWith("combo") || rhythm.data.title.toLowerCase().startsWith("combo");
const comboRhythms = rhythms.filter(isCombo);
const practiceRhythms = rhythms.filter((rhythm) => !isCombo(rhythm));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Baque Facil</title>
  </head>
  <body>
    <main class="page-shell">
      <header class="page-header">
        <h1>Baque Facil</h1>
        <p></p>
      </header>

      <section class="home-section" aria-labelledby="rhythms-heading">
        <h2 id="rhythms-heading">Rhythms</h2>
        <div class="rhythm-list">
          {
            practiceRhythms.map((rhythm) => (
              <a class="rhythm-link" href={`/rhythms/${rhythm.slug}/`}>
                <strong>{rhythm.data.title}</strong>
                <span>{rhythm.data.difficulty}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="home-section" aria-labelledby="combos-heading">
        <h2 id="combos-heading">Combos</h2>
        <div class="rhythm-list">
          {
            comboRhythms.map((rhythm) => (
              <a class="rhythm-link" href={`/rhythms/${rhythm.slug}/`}>
                <strong>{rhythm.data.title}</strong>
                <span>{rhythm.data.difficulty}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="home-section" aria-labelledby="composer-heading">
        <h2 id="composer-heading">Composer</h2>
        <a class="rhythm-link compose-link" href="/compose/">
          <strong>Compose an Alfaia rhythm</strong>
          <span>Keyboard-first editor</span>
        </a>
      </section>

      <details class="preference-disclosure">
        <summary>Settings</summary>
        <label class="hand-preference-toggle">
          <input id="left-handed-mode" type="checkbox" />
          <span>
            <strong>Left-handed mode</strong>
            <small>Reverse R (right) and L (left) in rhythm grids.</small>
          </span>
        </label>
      </details>
    </main>

    <script>
      import {
        readHandSymbolReversePreference,
        writeHandSymbolReversePreference,
      } from "../lib/handPreference";

      const leftHandedMode = document.querySelector<HTMLInputElement>("#left-handed-mode");

      if (leftHandedMode) {
        leftHandedMode.checked = readHandSymbolReversePreference();
        leftHandedMode.addEventListener("change", () => {
          writeHandSymbolReversePreference(leftHandedMode.checked);
        });
      }
    </script>
  </body>
</html>
