---
import { getCollection } from "astro:content";
import "../styles/global.css";

const rhythms = (await getCollection("rhythms")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Baque Facil</title>
  </head>
  <body>
    <main class="page-shell">
      <header class="page-header">
        <p class="eyebrow">Prototype</p>
        <h1>Baque Facil</h1>
        <p></p>
      </header>

      <section class="rhythm-list" aria-label="Rhythms">
        {
          rhythms.map((rhythm) => (
            <a class="rhythm-link" href={`/rhythms/${rhythm.slug}/`}>
              <strong>{rhythm.data.title}</strong>
              <span>{rhythm.data.difficulty}</span>
            </a>
          ))
        }

        <a class="rhythm-link compose-link" href="/compose/">
          <strong>Compose an Alfaia rhythm</strong>
          <span>Keyboard-first editor</span>
        </a>
      </section>

      <details class="preference-disclosure">
        <summary>Practice settings</summary>
        <label class="hand-preference-toggle">
          <input id="left-handed-mode" type="checkbox" />
          <span>
            <strong>Left-handed mode</strong>
            <small>Reverse R (right) and L (left) in rhythm grids.</small>
          </span>
        </label>
      </details>
    </main>

    <script>
      import {
        readHandSymbolReversePreference,
        writeHandSymbolReversePreference,
      } from "../lib/handPreference";

      const leftHandedMode = document.querySelector<HTMLInputElement>("#left-handed-mode");

      if (leftHandedMode) {
        leftHandedMode.checked = readHandSymbolReversePreference();
        leftHandedMode.addEventListener("change", () => {
          writeHandSymbolReversePreference(leftHandedMode.checked);
        });
      }
    </script>
  </body>
</html>
