---
import { ArrowLeft } from "lucide-react";
import RhythmComposer from "../components/RhythmComposer";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" href="/samples/alfaia/left-ghost.wav" as="audio" type="audio/wav" />
    <link rel="preload" href="/samples/alfaia/right-accent.wav" as="audio" type="audio/wav" />
    <title>Compose | Baque Facil</title>
  </head>
  <body>
    <main class="page-shell">
      <a class="back-link" href="/">
        <ArrowLeft aria-hidden="true" size={18} />
        All rhythms
      </a>

      <header class="page-header compact">
        <p class="eyebrow">Composer</p>
        <h1>Alfaia Composer</h1>
        <p>Record an Alfaia rhythm on a beat-based grid and export the transcription.</p>
      </header>

      <RhythmComposer client:load />
    </main>
  </body>
</html>
